# =============================================================================
# SetupGuide AI - variaveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# =============================================================================

# --- Supabase (frontend / server-side seguro) --------------------------------
# Encontrado em: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# URL usada em links de confirmacao de e-mail / reset de senha
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# As variaveis abaixo NAO vao no frontend. Sao configuradas como SECRETS
# da Edge Function no Supabase (supabase secrets set ...). Estao aqui apenas
# como referencia de documentacao.
# =============================================================================

# --- Edge Function ai-recommendations (server-only) --------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.5
# Injetadas automaticamente pelo runtime das Edge Functions:
# SUPABASE_URL=...
# SUPABASE_SERVICE_ROLE_KEY=...
